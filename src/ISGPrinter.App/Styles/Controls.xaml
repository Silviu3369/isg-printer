<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================ -->
    <!--  Base control styles. Default styles (no x:Key) so every    -->
    <!--  control inherits the modern look. Variants derive with     -->
    <!--  BasedOn and override brushes only — one template each.     -->
    <!-- ============================================================ -->

    <!-- ===================== Button (tactile) ===================== -->
    <!-- Raised, physical buttons: subtle vertical sheen (Background),
         1px top bevel highlight (Tag), darker outline (BorderBrush)
         and a layered drop shadow. Hover lifts the shadow; pressing
         depresses the button 1px and collapses the shadow. One
         template — variants override only brushes. -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SurfaceButtonFill}" />
        <Setter Property="Foreground" Value="{StaticResource TextBody}" />
        <Setter Property="BorderBrush" Value="{StaticResource SurfaceButtonOutline}" />
        <Setter Property="Tag" Value="{StaticResource SurfaceButtonBevel}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Height" Value="{StaticResource ControlHeight}" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="focusRing"
                                Margin="-3"
                                CornerRadius="9"
                                BorderThickness="2"
                                BorderBrush="{StaticResource Accent}"
                                Opacity="0" />
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusControl}"
                                Effect="{StaticResource ButtonShadowRest}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform />
                            </Border.RenderTransform>
                            <Border x:Name="bevel"
                                    CornerRadius="5"
                                    BorderThickness="0,1,0,0"
                                    BorderBrush="{TemplateBinding Tag}">
                                <Grid>
                                    <Border x:Name="stateLayer"
                                            Background="#0A1827"
                                            CornerRadius="5"
                                            Opacity="0" />
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"
                                                      RecognizesAccessKey="True" />
                                </Grid>
                            </Border>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="stateLayer" Property="Opacity" Value="0.05" />
                            <Setter TargetName="bd" Property="Effect" Value="{StaticResource ButtonShadowHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="stateLayer" Property="Opacity" Value="0.12" />
                            <Setter TargetName="bd" Property="Effect" Value="{StaticResource ButtonShadowPressed}" />
                            <Setter TargetName="bevel" Property="BorderBrush" Value="Transparent" />
                            <Setter TargetName="bd" Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="1" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="focusRing" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.45" />
                            <Setter TargetName="bd" Property="Effect" Value="{x:Null}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource AccentButtonFill}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentButtonOutline}" />
        <Setter Property="Tag" Value="{StaticResource AccentButtonBevel}" />
        <Setter Property="Foreground" Value="{StaticResource TextOnAccent}" />
    </Style>

    <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource GoodButtonFill}" />
        <Setter Property="BorderBrush" Value="{StaticResource GoodButtonOutline}" />
        <Setter Property="Tag" Value="{StaticResource GoodButtonBevel}" />
        <Setter Property="Foreground" Value="{StaticResource TextOnAccent}" />
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource CriticalButtonFill}" />
        <Setter Property="BorderBrush" Value="{StaticResource CriticalButtonOutline}" />
        <Setter Property="Tag" Value="{StaticResource CriticalButtonBevel}" />
        <Setter Property="Foreground" Value="{StaticResource TextOnAccent}" />
    </Style>

    <!-- Ghost stays intentionally flat — quiet tertiary actions -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource TextBody}" />
        <Setter Property="Height" Value="{StaticResource ControlHeight}" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="focusRing"
                                Margin="-3"
                                CornerRadius="9"
                                BorderThickness="2"
                                BorderBrush="{StaticResource Accent}"
                                Opacity="0" />
                        <Border x:Name="bd"
                                Background="Transparent"
                                CornerRadius="{StaticResource RadiusControl}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Pressed}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource BorderLight}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="focusRing" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Action-specific colored variants -->
    <Style x:Key="InfoButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource InfoButtonFill}" />
        <Setter Property="BorderBrush" Value="{StaticResource InfoButtonOutline}" />
        <Setter Property="Tag" Value="{StaticResource AccentButtonBevel}" />
        <Setter Property="Foreground" Value="{StaticResource TextOnAccent}" />
    </Style>

    <Style x:Key="DiscoverButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
