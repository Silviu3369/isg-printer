    <Style x:Key="SlateButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource SlateButtonFill}" />
        <Setter Property="BorderBrush" Value="{StaticResource SlateButtonOutline}" />
        <Setter Property="Tag" Value="{StaticResource AccentButtonBevel}" />
