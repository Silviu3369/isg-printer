<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:conv="clr-namespace:ISGPrinter.App.Converters">

    <!-- ============================================================ -->
    <!--  ISG Printer design tokens — single source of truth.        -->
    <!--  Neutrals are tinted toward the ISG blue hue (~206°);       -->
    <!--  text colors are NOT tinted (raw contrast, WCAG AA).        -->
    <!-- ============================================================ -->

    <!-- Accent -->
    <SolidColorBrush x:Key="Accent" Color="#1778C8" />
    <SolidColorBrush x:Key="AccentHover" Color="#1469B0" />
    <SolidColorBrush x:Key="AccentPressed" Color="#115E9E" />
    <SolidColorBrush x:Key="AccentTint" Color="#E3F0FB" />

    <!-- Neutral ramp -->
    <SolidColorBrush x:Key="WindowBackground" Color="#EFF4F9" />
    <SolidColorBrush x:Key="Surface" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Hover" Color="#F3F8FC" />
    <SolidColorBrush x:Key="Pressed" Color="#E7EFF6" />
    <SolidColorBrush x:Key="BorderLight" Color="#DCE5EE" />
    <SolidColorBrush x:Key="BorderMedium" Color="#C3D2DF" />

    <!-- Text (never tinted) -->
    <SolidColorBrush x:Key="TextStrong" Color="#16202A" />
    <SolidColorBrush x:Key="TextBody" Color="#33414F" />
    <SolidColorBrush x:Key="TextCaption" Color="#5A6B7C" />
    <SolidColorBrush x:Key="TextDisabled" Color="#93A3B3" />
    <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFF" />

    <!-- Semantic (dark enough for WCAG AA on their pale tints) -->
    <SolidColorBrush x:Key="Good" Color="#157033" />
    <SolidColorBrush x:Key="Info" Color="#1778C8" />
    <SolidColorBrush x:Key="Warning" Color="#A14A06" />
    <SolidColorBrush x:Key="Critical" Color="#C5261C" />
    <SolidColorBrush x:Key="GoodTint" Color="#DFF3E6" />
    <SolidColorBrush x:Key="InfoTint" Color="#E3F0FB" />
    <SolidColorBrush x:Key="WarningTint" Color="#FCEFD9" />
    <SolidColorBrush x:Key="CriticalTint" Color="#FBE4E2" />
    <SolidColorBrush x:Key="NeutralTint" Color="#E9EFF4" />

    <!-- Metrics -->
    <CornerRadius x:Key="RadiusControl">6</CornerRadius>
    <CornerRadius x:Key="RadiusCard">10</CornerRadius>
    <sys:Double x:Key="ControlHeight">34</sys:Double>

    <!-- Icon font: Fluent on Win11, MDL2 fallback on Win10 -->
    <FontFamily x:Key="IconFont">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

    <!-- Card shadow — soft, layered depth -->
    <DropShadowEffect x:Key="CardShadow"
                      BlurRadius="22"
                      ShadowDepth="3"
                      Direction="270"
                      Opacity="0.10"
                      Color="#1E293B" />

    <!-- ============================================================ -->
    <!--  Tactile button system (2025 premium): subtle vertical      -->
    <!--  sheen + top edge highlight + layered shadow. Buttons read  -->
    <!--  as physically raised; pressing depresses them 1px.         -->
    <!-- ============================================================ -->

    <LinearGradientBrush x:Key="AccentButtonFill" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#2E8FE0" Offset="0" />
        <GradientStop Color="#1571BD" Offset="0.55" />
        <GradientStop Color="#1162A6" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="AccentButtonOutline" Color="#0E548D" />
    <SolidColorBrush x:Key="AccentButtonBevel" Color="#59FFFFFF" />

    <LinearGradientBrush x:Key="SurfaceButtonFill" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0" />
        <GradientStop Color="#F9FBFD" Offset="0.6" />
        <GradientStop Color="#EFF4F9" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="SurfaceButtonOutline" Color="#B9C9D8" />
    <SolidColorBrush x:Key="SurfaceButtonBevel" Color="#E6FFFFFF" />

    <LinearGradientBrush x:Key="GoodButtonFill" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1E8C44" Offset="0" />
        <GradientStop Color="#146A2E" Offset="0.6" />
        <GradientStop Color="#0F5A26" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="GoodButtonOutline" Color="#0C4A20" />
    <SolidColorBrush x:Key="GoodButtonBevel" Color="#4DFFFFFF" />

    <LinearGradientBrush x:Key="CriticalButtonFill" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#D8453A" Offset="0" />
        <GradientStop Color="#B02318" Offset="0.6" />
        <GradientStop Color="#9A1B11" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="CriticalButtonOutline" Color="#8C150C" />
    <SolidColorBrush x:Key="CriticalButtonBevel" Color="#4DFFFFFF" />

    <!-- Action-specific button colors (tactile, white text, WCAG AA) -->
    <LinearGradientBrush x:Key="InfoButtonFill" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#2A95B4" Offset="0" />
        <GradientStop Color="#176E88" Offset="0.55" />
        <GradientStop Color="#135E74" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="InfoButtonOutline" Color="#0F4E60" />

    <LinearGradientBrush x:Key="DiscoverButtonFill" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#7E6BD6" Offset="0" />
        <GradientStop Color="#5E4ABF" Offset="0.55" />
        <GradientStop Color="#4E3DA6" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="DiscoverButtonOutline" Color="#3E318F" />

    <LinearGradientBrush x:Key="AmberButtonFill" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#C57F1E" Offset="0" />
        <GradientStop Color="#A5640F" Offset="0.55" />
        <GradientStop Color="#8C520A" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="AmberButtonOutline" Color="#6E4108" />

    <LinearGradientBrush x:Key="SlateButtonFill" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#6E8196" Offset="0" />
        <GradientStop Color="#54677B" Offset="0.55" />
        <GradientStop Color="#46586A" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="SlateButtonOutline" Color="#3A4A5A" />

    <DropShadowEffect x:Key="ButtonShadowRest"
                      BlurRadius="5"
                      ShadowDepth="1.5"
                      Direction="270"
                      Opacity="0.22"
                      Color="#23354A" />
    <DropShadowEffect x:Key="ButtonShadowHover"
                      BlurRadius="11"
                      ShadowDepth="3"
                      Direction="270"
                      Opacity="0.26"
                      Color="#23354A" />
    <DropShadowEffect x:Key="ButtonShadowPressed"
                      BlurRadius="2"
                      ShadowDepth="0"
                      Direction="270"
                      Opacity="0.20"
                      Color="#23354A" />

    <!-- ============================================================ -->
    <!--  Shell chrome: light marine blue frame (title bar, sidebar, -->
    <!--  status bar) — slightly translucent so Mica still breathes. -->
    <!-- ============================================================ -->
    <SolidColorBrush x:Key="TitleBarBackdrop" Color="#F0D6E4F1" />
    <SolidColorBrush x:Key="SidebarBackdrop" Color="#F0D6E4F1" />
    <SolidColorBrush x:Key="StatusBarBackdrop" Color="#F0D6E4F1" />

    <!-- Sidebar nav buttons: a step darker than the shell so each
         one reads as a distinct, raised physical key -->
    <SolidColorBrush x:Key="NavItemFill" Color="#C4D9EB" />
    <SolidColorBrush x:Key="NavItemFillHover" Color="#D2E4F2" />
    <SolidColorBrush x:Key="NavItemBorder" Color="#A8C3DC" />
    <SolidColorBrush x:Key="NavItemText" Color="#21384F" />
    <SolidColorBrush x:Key="NavIconIdle" Color="#3E5872" />

    <!-- 3D button texture: a subtle sheen (bright top, dark bottom)
         overlaid on any base color, plus a top bevel highlight and a
         soft inner bottom shade. Reusable on idle and active states. -->
    <LinearGradientBrush x:Key="ButtonSheen" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#26FFFFFF" Offset="0" />
        <GradientStop Color="#0DFFFFFF" Offset="0.48" />
        <GradientStop Color="#0A000000" Offset="0.52" />
        <GradientStop Color="#26000000" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ButtonBevel" Color="#73FFFFFF" />

    <DropShadowEffect x:Key="NavShadowRest"
                      ShadowDepth="2"
                      BlurRadius="6"
                      Direction="270"
                      Opacity="0.24"
                      Color="#2A3F57" />
    <DropShadowEffect x:Key="NavShadowHover"
                      ShadowDepth="3"
                      BlurRadius="10"
                      Direction="270"
                      Opacity="0.28"
                      Color="#2A3F57" />
    <DropShadowEffect x:Key="NavShadowPressed"
                      ShadowDepth="0"
                      BlurRadius="2"
                      Direction="270"
                      Opacity="0.18"
                      Color="#2A3F57" />

    <!-- Glass (idle nav): translucent frosted fill so the marine shell
         and Mica read through. Light frosted edge + faint lift only. -->
    <LinearGradientBrush x:Key="NavGlassFill" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#64FFFFFF" Offset="0" />
        <GradientStop Color="#3CFFFFFF" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="NavGlassFillHover" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#96FFFFFF" Offset="0" />
        <GradientStop Color="#70FFFFFF" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="NavGlassBorder" Color="#A8FFFFFF" />
    <DropShadowEffect x:Key="NavGlassShadow"
                      ShadowDepth="1"
                      BlurRadius="4"
                      Direction="270"
                      Opacity="0.10"
                      Color="#2A3F57" />

    <!-- Muted text that stays AA-readable on the marine shell -->
    <SolidColorBrush x:Key="ShellCaption" Color="#44586C" />

    <Style x:Key="ShellCaptionText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ShellCaption}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <conv:EmptyToDashConverter x:Key="EmptyToDash" />

    <!-- Typography -->
    <Style x:Key="PageTitleText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SectionTitleText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="CaptionText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextCaption}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- Kept under its old name so existing markup keeps working -->
    <Style x:Key="MutedText" TargetType="TextBlock" BasedOn="{StaticResource CaptionText}" />

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextCaption}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,3" />
    </Style>

    <Style x:Key="FieldValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextBody}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="IconText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource IconFont}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
