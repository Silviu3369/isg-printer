<UserControl x:Class="ISGPrinter.App.Views.Pages.PrintersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Printers module accent (azure), used for the page identity -->
        <SolidColorBrush x:Key="PA" Color="#1C6FD0" />
        <SolidColorBrush x:Key="PADeep" Color="#13569F" />
        <SolidColorBrush x:Key="PATint" Color="#E8F1FC" />
        <LinearGradientBrush x:Key="PATile" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#3A93E6" Offset="0" />
            <GradientStop Color="#1C6FD0" Offset="0.55" />
            <GradientStop Color="#175FB8" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextCaption}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBody}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RenderTransform>
            <TranslateTransform />
        </Grid.RenderTransform>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard Storyboard="{StaticResource PageIntroStoryboard}" />
            </EventTrigger>
        </Grid.Triggers>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Page header + toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Printers" Style="{StaticResource PageTitleText}" />
                    <Border Style="{StaticResource StatusPill}"
                            Background="{StaticResource PATint}"
                            Margin="10,4,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource StatusPillText}"
                                   Foreground="{StaticResource PADeep}"
                                   Text="{Binding Printers.Count, StringFormat={}{0} printers}" />
                    </Border>
                </StackPanel>
                <TextBlock Text="Company printer discovery and technician actions"
                           Style="{StaticResource CaptionText}"
                           Margin="0,3,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Bottom">
                <TextBox Width="230"
                         Text="{Binding NewServerName, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Print server name, e.g. PRINTSRV01"
                         VerticalAlignment="Center" />
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding AddServerCommand}"
                        Margin="8,0,0,0"
                        ToolTip="Add this print server to the known servers list and refresh">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;"
                                   FontFamily="{StaticResource IconFont}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Add Server" Margin="7,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding AutoDetectCommand}"
                        Style="{StaticResource DiscoverButton}"
                        Margin="8,0,0,0"
                        ToolTip="Find print servers automatically — from installed network printers and (on a domain) from Active Directory">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE721;"
                                   FontFamily="{StaticResource IconFont}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Auto-detect" Margin="7,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding RefreshCommand}"
                        Style="{StaticResource InfoButton}"
                        Margin="8,0,0,0"
                        ToolTip="Re-run printer discovery on all known servers">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="{StaticResource IconFont}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Refresh" Margin="7,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ScanNetworkCommand}"
                        Style="{StaticResource SlateButton}"
                        Margin="8,0,0,0"
                        ToolTip="Scan the local subnet for direct-IP network printers (port 9100)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE968;"
                                   FontFamily="{StaticResource IconFont}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Scan" Margin="7,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding CancelOperationCommand}"
                        Style="{StaticResource DangerButton}"
                        Margin="8,0,0,0"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                        ToolTip="Cancel the current discovery or scan operation">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE711;"
                                   FontFamily="{StaticResource IconFont}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Cancel" Margin="7,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Loading -->
        <ProgressBar Grid.Row="1"
                     Height="3"
                     Margin="0,0,0,12"
                     IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

        <!-- Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="304" />
            </Grid.ColumnDefinitions>

            <!-- Printer table -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Padding="16,13"
                            BorderBrush="{StaticResource BorderLight}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="Discovered Printers" Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="Select a printer to review details, or double-click to install."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1"
                              Margin="4,2,4,6"
                              ItemsSource="{Binding PrintersView}"
                              SelectedItem="{Binding SelectedPrinter}"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding InstallSelectedCommand}" />
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" ElementStyle="{StaticResource GridText}" Width="1.6*" MinWidth="130" />
                            <DataGridTextColumn Header="UNC" Binding="{Binding UncPath}" ElementStyle="{StaticResource GridText}" Width="1.9*" MinWidth="150" />
                            <DataGridTextColumn Header="Server" Binding="{Binding ServerName}" ElementStyle="{StaticResource GridText}" Width="*" MinWidth="80" />
                            <DataGridTextColumn Header="Driver" Binding="{Binding DriverName}" ElementStyle="{StaticResource GridText}" Width="1.3*" MinWidth="110" />

                            <DataGridTemplateColumn Header="State" Width="116">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource StatusPill}">
                                                    <Setter Property="Background" Value="{StaticResource NeutralTint}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsInstalledLocally}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource GoodTint}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,6,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{StaticResource TextCaption}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsInstalledLocally}" Value="True">
                                                                    <Setter Property="Fill" Value="{StaticResource Good}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource StatusPillText}">
                                                            <Setter Property="Text" Value="Available" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsInstalledLocally}" Value="True">
                                                                    <Setter Property="Text" Value="Installed" />
                                                                    <Setter Property="Foreground" Value="{StaticResource Good}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Default" Width="72">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{StaticResource IconFont}"
                                                   FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                            <Setter Property="Text" Value="&#xE735;" />
                                                            <Setter Property="Foreground" Value="{StaticResource PA}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state -->
                    <StackPanel Grid.Row="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="280">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding PrintersView.IsEmpty}" Value="True" />
                                            <Condition Binding="{Binding IsLoading}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Style="{StaticResource EmptyStateGlyph}" Text="&#xE749;" />
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTitle}">
                                    <Setter Property="Text" Value="No matching printers" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterText}" Value="">
                                            <Setter Property="Text" Value="No printers discovered" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateText}">
                                    <Setter Property="Text" Value="No printers match the current search. Clear the search box to see all printers." />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterText}" Value="">
                                            <Setter Property="Text" Value="Add a print server above to discover company printers." />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Details panel -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            Padding="16,14"
                            BorderBrush="{StaticResource BorderLight}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="44"
                                    Height="44"
                                    CornerRadius="11"
                                    Background="{StaticResource PATile}"
                                    Effect="{StaticResource CardShadow}">
                                <TextBlock Text="&#xE749;"
                                           FontFamily="{StaticResource IconFont}"
                                           FontSize="20"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextStrong}"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding SelectedPrinter.Name, TargetNullValue=Printer details, FallbackValue=Printer details}" />
                                <TextBlock Style="{StaticResource CaptionText}"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding SelectedPrinter.UncPath, TargetNullValue=No printer selected, FallbackValue=No printer selected}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Empty state -->
                    <StackPanel Grid.Row="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="220">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPrinter}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Style="{StaticResource EmptyStateGlyph}" Text="&#xE8B0;" />
                        <TextBlock Style="{StaticResource EmptyStateTitle}" Text="No printer selected" />
                        <TextBlock Style="{StaticResource EmptyStateText}"
                                   Text="Select a printer from the table to see details and run actions." />
                    </StackPanel>

                    <!-- Details -->
                    <ScrollViewer Grid.Row="1"
                                  Padding="16,14"
                                  VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPrinter}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <StackPanel>
                            <!-- State pills -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource StatusPill}">
                                            <Setter Property="Background" Value="{StaticResource NeutralTint}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPrinter.IsInstalledLocally}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource GoodTint}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="{StaticResource IconFont}" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#xECC9;" />
                                                    <Setter Property="Foreground" Value="{StaticResource TextCaption}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedPrinter.IsInstalledLocally}" Value="True">
                                                            <Setter Property="Text" Value="&#xE73E;" />
                                                            <Setter Property="Foreground" Value="{StaticResource Good}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusPillText}">
                                                    <Setter Property="Text" Value="Available" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedPrinter.IsInstalledLocally}" Value="True">
                                                            <Setter Property="Text" Value="Installed" />
                                                            <Setter Property="Foreground" Value="{StaticResource Good}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatusPill}"
                                        Background="{StaticResource PATint}"
                                        Margin="8,0,0,0"
                                        Visibility="{Binding SelectedPrinter.IsDefault, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE735;" FontFamily="{StaticResource IconFont}" FontSize="11" Foreground="{StaticResource PA}" VerticalAlignment="Center" Margin="0,0,5,0" />
                                        <TextBlock Text="Default" Style="{StaticResource StatusPillText}" Foreground="{StaticResource PADeep}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="SERVER" Style="{StaticResource DetailLabel}" />
                                    <TextBlock Text="{Binding SelectedPrinter.ServerName, Converter={StaticResource EmptyToDash}}" Style="{StaticResource DetailValue}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="PORT" Style="{StaticResource DetailLabel}" />
                                    <TextBlock Text="{Binding SelectedPrinter.PortName, Converter={StaticResource EmptyToDash}}" Style="{StaticResource DetailValue}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="DRIVER" Style="{StaticResource DetailLabel}" />
                            <TextBlock Text="{Binding SelectedPrinter.DriverName, Converter={StaticResource EmptyToDash}}" Style="{StaticResource DetailValue}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="LOCATION" Style="{StaticResource DetailLabel}" />
                                    <TextBlock Text="{Binding SelectedPrinter.Location, Converter={StaticResource EmptyToDash}}" Style="{StaticResource DetailValue}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="IP ADDRESS" Style="{StaticResource DetailLabel}" />
                                    <TextBlock Text="{Binding SelectedPrinter.IpAddress, Converter={StaticResource EmptyToDash}}" Style="{StaticResource DetailValue}" />
                                </StackPanel>
                            </Grid>

                            <!-- Live SNMP read -->
                            <Button Style="{StaticResource GhostButton}"
                                    HorizontalAlignment="Left"
                                    Margin="0,2,0,0"
                                    Command="{Binding ReadSuppliesCommand}"
                                    ToolTip="Read toner, model, serial and page count from the printer over SNMP (uses the profile in Settings)">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE9D9;" FontFamily="{StaticResource IconFont}" FontSize="12" Foreground="{StaticResource PA}" VerticalAlignment="Center" />
                                    <TextBlock Text="Read supplies (SNMP)" Margin="7,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource PADeep}" />
                                </StackPanel>
                            </Button>

                            <Border Background="{StaticResource PATint}"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,8,0,0"
                                    Visibility="{Binding HasLiveData, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="LIVE (SNMP)" Style="{StaticResource DetailLabel}" Foreground="{StaticResource PADeep}" />
                                    <TextBlock Text="Toner" Style="{StaticResource DetailLabel}" Margin="0,6,0,2" />
                                    <TextBlock Text="{Binding LiveToner, Converter={StaticResource EmptyToDash}}" Style="{StaticResource DetailValue}" Margin="0,0,0,8" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,10,0">
                                            <TextBlock Text="Model" Style="{StaticResource DetailLabel}" />
                                            <TextBlock Text="{Binding LiveModel, Converter={StaticResource EmptyToDash}}" Style="{StaticResource DetailValue}" Margin="0,0,0,8" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Pages" Style="{StaticResource DetailLabel}" />
                                            <TextBlock Text="{Binding LivePageCount, Converter={StaticResource EmptyToDash}}" Style="{StaticResource DetailValue}" Margin="0,0,0,8" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="Serial" Style="{StaticResource DetailLabel}" />
                                    <TextBlock Text="{Binding LiveSerial, Converter={StaticResource EmptyToDash}}" Style="{StaticResource DetailValue}" Margin="0,0,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Actions -->
                    <Border Grid.Row="2"
                            Padding="16,12"
                            BorderBrush="{StaticResource BorderLight}"
                            BorderThickness="0,1,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPrinter}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Button Command="{Binding InstallSelectedCommand}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,8"
                                    ToolTip="Install the selected printer connection for the current elevated account">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPrinter.IsInstalledLocally}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource IconFont}" FontSize="12" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#xE896;" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedPrinter.IsInstalledLocally}" Value="True">
                                                        <Setter Property="Text" Value="&#xE73E;" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Margin="7,0,0,0" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Install Printer" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedPrinter.IsInstalledLocally}" Value="True">
                                                        <Setter Property="Text" Value="Already Installed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SetDefaultSelectedCommand}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,8"
                                    ToolTip="Set the selected printer as default for the current elevated account">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource InfoButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPrinter.IsDefault}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE735;" FontFamily="{StaticResource IconFont}" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Margin="7,0,0,0" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Set Default" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedPrinter.IsDefault}" Value="True">
                                                        <Setter Property="Text" Value="Default Printer" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SlateButton}"
                                    Command="{Binding CopyUncCommand}"
                                    HorizontalAlignment="Stretch"
                                    ToolTip="Copy the UNC path to the clipboard">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFont}" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Text="Copy UNC" Margin="7,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Status -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="2,10,0,0">
            <TextBlock Text="&#xE946;"
                       FontFamily="{StaticResource IconFont}"
                       FontSize="12"
                       Foreground="{StaticResource TextCaption}"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0" />
            <TextBlock Text="{Binding StatusText}"
                       Style="{StaticResource CaptionText}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </Grid>
</UserControl>
