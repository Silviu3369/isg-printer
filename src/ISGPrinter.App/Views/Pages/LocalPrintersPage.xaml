<UserControl x:Class="ISGPrinter.App.Views.Pages.LocalPrintersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Local Printers module accent (teal) -->
        <SolidColorBrush x:Key="LA" Color="#0C857A" />
        <SolidColorBrush x:Key="LADeep" Color="#0A6B62" />
        <SolidColorBrush x:Key="LATint" Color="#E2F3F0" />
        <LinearGradientBrush x:Key="LATile" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#16A192" Offset="0" />
            <GradientStop Color="#0C857A" Offset="0.55" />
            <GradientStop Color="#0A6F66" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextCaption}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBody}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RenderTransform>
            <TranslateTransform />
        </Grid.RenderTransform>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard Storyboard="{StaticResource PageIntroStoryboard}" />
            </EventTrigger>
        </Grid.Triggers>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Local Printers" Style="{StaticResource PageTitleText}" />
                    <Border Style="{StaticResource StatusPill}"
                            Background="{StaticResource LATint}"
                            Margin="10,4,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource StatusPillText}"
                                   Foreground="{StaticResource LADeep}"
                                   Text="{Binding Printers.Count, StringFormat={}{0} installed}" />
                    </Border>
                </StackPanel>
                <TextBlock Text="Installed printers for the current elevated Windows account"
                           Style="{StaticResource CaptionText}"
                           Margin="0,3,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Bottom">
                <Button Command="{Binding RestartSpoolerCommand}"
                        Style="{StaticResource WarningButton}"
                        ToolTip="Stop and start the Windows Print Spooler service (needs administrator)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE777;" FontFamily="{StaticResource IconFont}" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Restart Spooler" Margin="7,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding RefreshCommand}"
                        Style="{StaticResource InfoButton}"
                        Margin="8,0,0,0"
                        ToolTip="Re-read installed printers from Windows">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Refresh" Margin="7,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Loading -->
        <ProgressBar Grid.Row="1"
                     Height="3"
                     Margin="0,0,0,12"
                     IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

        <!-- Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="330" />
            </Grid.ColumnDefinitions>

            <!-- Printer table -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <DataGrid Margin="4,4,4,6"
                              ItemsSource="{Binding PrintersView}"
                              SelectedItem="{Binding SelectedPrinter}"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" ElementStyle="{StaticResource GridText}" Width="1.8*" MinWidth="150" />
                            <DataGridTemplateColumn Header="Default" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{StaticResource IconFont}"
                                                   FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                            <Setter Property="Text" Value="&#xE735;" />
                                                            <Setter Property="Foreground" Value="{StaticResource LA}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Driver" Binding="{Binding DriverName}" ElementStyle="{StaticResource GridText}" Width="1.6*" MinWidth="130" />
                            <DataGridTextColumn Header="Port" Binding="{Binding PortName}" ElementStyle="{StaticResource GridText}" Width="*" MinWidth="80" />
                            <DataGridTextColumn Header="Connection" Binding="{Binding ConnectionType}" ElementStyle="{StaticResource GridText}" Width="110" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" ElementStyle="{StaticResource GridText}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="280">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding PrintersView.IsEmpty}" Value="True" />
                                            <Condition Binding="{Binding IsLoading}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Style="{StaticResource EmptyStateGlyph}" Text="&#xE772;" />
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTitle}">
                                    <Setter Property="Text" Value="No matching printers" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterText}" Value="">
                                            <Setter Property="Text" Value="No local printers" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateText}">
                                    <Setter Property="Text" Value="No printers match the current search. Clear the search box to see all printers." />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterText}" Value="">
                                            <Setter Property="Text" Value="No printers are installed for this elevated account yet." />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Details + actions + queue -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            Padding="16,14"
                            BorderBrush="{StaticResource BorderLight}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="44"
                                    Height="44"
                                    CornerRadius="11"
                                    Background="{StaticResource LATile}"
                                    Effect="{StaticResource CardShadow}">
                                <TextBlock Text="&#xE772;"
                                           FontFamily="{StaticResource IconFont}"
                                           FontSize="20"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextStrong}"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding SelectedPrinter.Name, TargetNullValue=Printer details, FallbackValue=Printer details}" />
                                <TextBlock Style="{StaticResource CaptionText}"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding SelectedPrinter.ConnectionType, TargetNullValue=No printer selected, FallbackValue=No printer selected, StringFormat={}{0} printer}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Empty state -->
                    <StackPanel Grid.Row="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="220">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPrinter}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Style="{StaticResource EmptyStateGlyph}" Text="&#xE8B0;" />
                        <TextBlock Style="{StaticResource EmptyStateTitle}" Text="No printer selected" />
                        <TextBlock Style="{StaticResource EmptyStateText}"
                                   Text="Select a printer to see details, manage its queue, and run actions." />
                    </StackPanel>

                    <!-- Details + queue -->
                    <ScrollViewer Grid.Row="1"
                                  Padding="16,14"
                                  VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPrinter}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <StackPanel>
                            <!-- Pills -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Style="{StaticResource StatusPill}"
                                        Background="{StaticResource LATint}"
                                        Visibility="{Binding SelectedPrinter.IsDefault, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE735;" FontFamily="{StaticResource IconFont}" FontSize="11" Foreground="{StaticResource LA}" VerticalAlignment="Center" Margin="0,0,5,0" />
                                        <TextBlock Text="Default" Style="{StaticResource StatusPillText}" Foreground="{StaticResource LADeep}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatusPill}" Margin="0,0,0,0">
                                    <TextBlock Text="{Binding SelectedPrinter.Status}" Style="{StaticResource StatusPillText}" />
                                </Border>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="PORT" Style="{StaticResource DetailLabel}" />
                                    <TextBlock Text="{Binding SelectedPrinter.PortName, Converter={StaticResource EmptyToDash}}" Style="{StaticResource DetailValue}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="CONNECTION" Style="{StaticResource DetailLabel}" />
                                    <TextBlock Text="{Binding SelectedPrinter.ConnectionType}" Style="{StaticResource DetailValue}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="DRIVER" Style="{StaticResource DetailLabel}" />
                            <TextBlock Text="{Binding SelectedPrinter.DriverName, Converter={StaticResource EmptyToDash}}" Style="{StaticResource DetailValue}" />

                            <TextBlock Text="SERVER / UNC" Style="{StaticResource DetailLabel}" />
                            <TextBlock Text="{Binding SelectedPrinter.UncPath, Converter={StaticResource EmptyToDash}}" Style="{StaticResource DetailValue}" />

                            <!-- Live SNMP read (printers on a TCP/IP port) -->
                            <Button Style="{StaticResource GhostButton}"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,0"
                                    Command="{Binding ReadSuppliesCommand}"
                                    ToolTip="Read toner, model, serial and page count over SNMP (resolves the printer's IP from its port; uses the profile in Settings)">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE9D9;" FontFamily="{StaticResource IconFont}" FontSize="12" Foreground="{StaticResource LA}" VerticalAlignment="Center" />
                                    <TextBlock Text="Read supplies (SNMP)" Margin="7,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource LADeep}" />
                                </StackPanel>
                            </Button>

                            <Border Background="{StaticResource LATint}"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,8,0,0"
                                    Visibility="{Binding HasLiveData, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="LIVE (SNMP)" Style="{StaticResource DetailLabel}" Foreground="{StaticResource LADeep}" />
                                    <TextBlock Text="Toner" Style="{StaticResource DetailLabel}" Margin="0,6,0,2" />
                                    <TextBlock Text="{Binding LiveToner, Converter={StaticResource EmptyToDash}}" Style="{StaticResource DetailValue}" Margin="0,0,0,8" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,10,0">
                                            <TextBlock Text="Model" Style="{StaticResource DetailLabel}" />
                                            <TextBlock Text="{Binding LiveModel, Converter={StaticResource EmptyToDash}}" Style="{StaticResource DetailValue}" Margin="0,0,0,8" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Pages" Style="{StaticResource DetailLabel}" />
                                            <TextBlock Text="{Binding LivePageCount, Converter={StaticResource EmptyToDash}}" Style="{StaticResource DetailValue}" Margin="0,0,0,8" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="Serial" Style="{StaticResource DetailLabel}" />
                                    <TextBlock Text="{Binding LiveSerial, Converter={StaticResource EmptyToDash}}" Style="{StaticResource DetailValue}" Margin="0,0,0,0" />
                                </StackPanel>
                            </Border>

                            <Separator Margin="0,12,0,12" />

                            <!-- Print queue -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Print queue" Style="{StaticResource SectionTitleText}" />
                                    <Border Style="{StaticResource StatusPill}"
                                            Background="{StaticResource NeutralTint}"
                                            Margin="8,1,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Jobs.Count}" Style="{StaticResource StatusPillText}" />
                                    </Border>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource GhostButton}"
                                        Height="28"
                                        Padding="8,0"
                                        Command="{Binding RefreshJobsCommand}"
                                        ToolTip="Refresh the print queue">
                                    <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}" FontSize="12" />
                                </Button>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Jobs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Hover}"
                                                BorderBrush="{StaticResource BorderLight}"
                                                BorderThickness="1"
                                                CornerRadius="7"
                                                Padding="10,7"
                                                Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Document}"
                                                               FontSize="12.5"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextStrong}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock Text="{Binding Owner}" Style="{StaticResource CaptionText}" />
                                                        <TextBlock Text="•" Style="{StaticResource CaptionText}" Margin="6,0" />
                                                        <TextBlock Text="{Binding Status}" Style="{StaticResource CaptionText}" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Style="{StaticResource GhostButton}"
                                                        Height="26"
                                                        Padding="6,0"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding DataContext.CancelJobCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Cancel this job">
                                                    <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="12" Foreground="{StaticResource Critical}" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Queue empty -->
                            <Border Background="{StaticResource LATint}"
                                    CornerRadius="8"
                                    Padding="11,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Jobs.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}" FontSize="13" Foreground="{StaticResource LA}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Queue is empty — nothing waiting to print." Foreground="{StaticResource LADeep}" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <Button Style="{StaticResource GhostButton}"
                                    HorizontalAlignment="Left"
                                    Margin="0,8,0,0"
                                    Command="{Binding ClearQueueCommand}"
                                    ToolTip="Cancel and remove all jobs in this printer's queue">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="12" Foreground="{StaticResource Critical}" VerticalAlignment="Center" />
                                    <TextBlock Text="Clear queue" Margin="7,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Critical}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Actions -->
                    <Border Grid.Row="2"
                            Padding="16,12"
                            BorderBrush="{StaticResource BorderLight}"
                            BorderThickness="0,1,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPrinter}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Button Command="{Binding PrintTestPageCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,8"
                                    ToolTip="Send a Windows test page to this printer">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE749;" FontFamily="{StaticResource IconFont}" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Text="Print Test Page" Margin="7,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Command="{Binding SetDefaultSelectedCommand}"
                                        HorizontalAlignment="Stretch"
                                        ToolTip="Set as the default printer for this account">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource InfoButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPrinter.IsDefault}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE735;" FontFamily="{StaticResource IconFont}" FontSize="12" VerticalAlignment="Center" />
                                        <TextBlock Text="Default" Margin="7,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2"
                                        Style="{StaticResource DangerButton}"
                                        Command="{Binding RemovePrinterCommand}"
                                        HorizontalAlignment="Stretch"
                                        ToolTip="Remove (uninstall) this printer from the computer">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="12" VerticalAlignment="Center" />
                                        <TextBlock Text="Remove" Margin="7,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Status -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="2,10,0,0">
            <TextBlock Text="&#xE946;"
                       FontFamily="{StaticResource IconFont}"
                       FontSize="12"
                       Foreground="{StaticResource TextCaption}"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0" />
            <TextBlock Text="{Binding StatusText}"
                       Style="{StaticResource CaptionText}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </Grid>
</UserControl>
