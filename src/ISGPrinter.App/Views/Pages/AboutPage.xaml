<UserControl x:Class="ISGPrinter.App.Views.Pages.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ISGPrinter.App.Views.Controls">
    <UserControl.Resources>
        <!-- About module accent (indigo) -->
        <SolidColorBrush x:Key="AB" Color="#4A63C4" />
        <SolidColorBrush x:Key="ABDeep" Color="#384EA0" />
        <SolidColorBrush x:Key="ABTint" Color="#EAEDFB" />
        <LinearGradientBrush x:Key="ABTile" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#6072D6" Offset="0" />
            <GradientStop Color="#4A63C4" Offset="0.55" />
            <GradientStop Color="#3B4FA6" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="AboutLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextCaption}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="AboutValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBody}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RenderTransform>
            <TranslateTransform />
        </Grid.RenderTransform>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard Storyboard="{StaticResource PageIntroStoryboard}" />
            </EventTrigger>
        </Grid.Triggers>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Identity card -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="22" Margin="0,0,0,14">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="58"
                            Height="58"
                            CornerRadius="13"
                            Background="{StaticResource ABTile}"
                            Effect="{StaticResource CardShadow}">
                        <controls:BrandLogo Width="40" Height="40" />
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding AppName}"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextStrong}" />
                            <Border Style="{StaticResource StatusPill}"
                                    Background="{StaticResource ABTint}"
                                    Margin="10,6,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource StatusPillText}"
                                           Foreground="{StaticResource ABDeep}"
                                           Text="{Binding Version, StringFormat=v{0}}" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Technician Console"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
                <TextBlock Text="{Binding Description}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextBody}"
                           LineHeight="20"
                           Margin="0,16,0,0" />

                <Separator Margin="0,16,0,14" />

                <TextBlock Text="WHAT IT DOES"
                           Foreground="{StaticResource TextCaption}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10" />
                <ItemsControl ItemsSource="{Binding Features}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="6"
                                         Height="6"
                                         Fill="{StaticResource AB}"
                                         VerticalAlignment="Top"
                                         Margin="2,6,10,0" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding}"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextBody}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,8,0,14" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="MADE BY" Style="{StaticResource AboutLabel}" />
                        <TextBlock Text="{Binding Author}"
                                   Foreground="{StaticResource TextStrong}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Copyright}"
                               Style="{StaticResource CaptionText}"
                               VerticalAlignment="Bottom" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Details -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- System snapshot -->
            <Border Grid.Column="0" Style="{StaticResource Card}" VerticalAlignment="Top">
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="System Snapshot" Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="The environment this session is running in."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource SlateButton}"
                                Height="30"
                                Command="{Binding CopyEnvironmentInfoCommand}"
                                VerticalAlignment="Top"
                                ToolTip="Copy this environment block for a ticket">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFont}" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="Copy" Margin="6,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="30" />
                            <RowDefinition Height="30" />
                            <RowDefinition Height="30" />
                            <RowDefinition Height="30" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="COMPUTER" Style="{StaticResource AboutLabel}" />
                        <TextBlock Grid.Column="1" Text="{Binding ComputerName}" Style="{StaticResource AboutValue}" />

                        <TextBlock Grid.Row="1" Text="USER" Style="{StaticResource AboutLabel}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UserName}" Style="{StaticResource AboutValue}" />

                        <TextBlock Grid.Row="2" Text="DOMAIN" Style="{StaticResource AboutLabel}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DomainName}" Style="{StaticResource AboutValue}" />

                        <TextBlock Grid.Row="3" Text="WINDOWS" Style="{StaticResource AboutLabel}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding WindowsVersion}" Style="{StaticResource AboutValue}" />

                        <TextBlock Grid.Row="4" Text="ELEVATION" Style="{StaticResource AboutLabel}" />
                        <Border Grid.Row="4" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StatusPill}">
                                    <Setter Property="Background" Value="{StaticResource CriticalTint}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsElevated}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource GoodTint}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource StatusPillText}">
                                        <Setter Property="Text" Value="Not elevated" />
                                        <Setter Property="Foreground" Value="{StaticResource Critical}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsElevated}" Value="True">
                                                <Setter Property="Text" Value="Administrator" />
                                                <Setter Property="Foreground" Value="{StaticResource Good}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Build & locations -->
            <Border Grid.Column="2" Style="{StaticResource Card}" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Build &amp; Storage" Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="How this build stores data on the PC."
                               Style="{StaticResource CaptionText}"
                               Margin="0,2,0,14" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="BUILD DATE" Style="{StaticResource AboutLabel}" />
                            <TextBlock Text="{Binding BuildDate}" Style="{StaticResource AboutValue}" Margin="0,3,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="PLATFORM" Style="{StaticResource AboutLabel}" />
                            <TextBlock Text="{Binding Platform}" Style="{StaticResource AboutValue}" Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>

                    <Separator Margin="0,2,0,12" />

                    <TextBlock Text="STORAGE" Style="{StaticResource AboutLabel}" Margin="0,0,0,6" />
                    <Border Background="{StaticResource ABTint}"
                            CornerRadius="8"
                            Padding="11,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE730;"
                                       FontFamily="{StaticResource IconFont}"
                                       FontSize="14"
                                       Foreground="{StaticResource AB}"
                                       VerticalAlignment="Top"
                                       Margin="0,1,9,0" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding StorageMode}"
                                       Foreground="{StaticResource ABDeep}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="2,12,0,0">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusText}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="&#xE946;"
                       FontFamily="{StaticResource IconFont}"
                       FontSize="12"
                       Foreground="{StaticResource TextCaption}"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0" />
            <TextBlock Text="{Binding StatusText}"
                       Style="{StaticResource CaptionText}"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
