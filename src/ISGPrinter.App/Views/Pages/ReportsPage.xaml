<UserControl x:Class="ISGPrinter.App.Views.Pages.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RenderTransform>
            <TranslateTransform />
        </Grid.RenderTransform>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard Storyboard="{StaticResource PageIntroStoryboard}" />
            </EventTrigger>
        </Grid.Triggers>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Reports" Style="{StaticResource PageTitleText}" />
                <TextBlock Text="Ticket-ready diagnostic report — generate, copy or save to a file."
                           Style="{StaticResource CaptionText}"
                           Margin="0,3,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <ComboBox Width="200"
                          VerticalAlignment="Center"
                          ItemsSource="{Binding Printers}"
                          SelectedItem="{Binding SelectedPrinter}"
                          ToolTip="Choose which printer to report on">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding GenerateReportCommand}"
                        Margin="8,0,0,0"
                        ToolTip="Run diagnostics on the selected printer and build a report">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Generate" Margin="7,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding CopyReportCommand}"
                        Style="{StaticResource SlateButton}"
                        Margin="8,0,0,0"
                        ToolTip="Copy the report to the clipboard">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFont}" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Copy" Margin="7,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding SaveReportCommand}"
                        Style="{StaticResource SuccessButton}"
                        Margin="8,0,0,0"
                        ToolTip="Save the report to a text file">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" FontFamily="{StaticResource IconFont}" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Save" Margin="7,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Loading -->
        <ProgressBar Grid.Row="1"
                     Height="3"
                     Margin="0,0,0,12"
                     IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

        <!-- Report -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="2">
            <Grid>
                <TextBox Text="{Binding ReportContent, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         Height="Auto"
                         VerticalAlignment="Stretch"
                         VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="12,10"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="12.5"
                         Visibility="{Binding HasReport, Converter={StaticResource BoolToVis}}" />

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="320">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasReport}" Value="False" />
                                        <Condition Binding="{Binding IsLoading}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Style="{StaticResource EmptyStateGlyph}" Text="&#xE9F9;" />
                    <TextBlock Style="{StaticResource EmptyStateTitle}" Text="No report yet" />
                    <TextBlock Style="{StaticResource EmptyStateText}"
                               Text="Pick a printer and choose Generate to build a ticket-ready diagnostic report." />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="2,10,0,0">
            <TextBlock Text="&#xE946;"
                       FontFamily="{StaticResource IconFont}"
                       FontSize="12"
                       Foreground="{StaticResource TextCaption}"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0" />
            <TextBlock Text="{Binding StatusText}"
                       Style="{StaticResource CaptionText}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </Grid>
</UserControl>
